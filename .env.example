# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# New Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional: PDF generation
PUPPETEER_EXECUTABLE_PATH=

# Optional: Stripe Checkout for platform license purchase
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=price_1TI2gaCzoVNlY4w2Uzw5YCuh
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_PLATFORM_MANUAL_PAYMENT_ENABLED=0

# Optional: AI / external channels
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1-chat-latest
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
DISCORD_PUBLIC_KEY=
DISCORD_APP_ID=
DISCORD_BOT_TOKEN=
DISCORD_REDIRECT_URI=
EXTERNAL_AI_SHARED_SECRET=
INVOICE_REMINDER_CRON_SECRET=

# Optional: month close external adapters
FREEE_CLIENT_ID=
FREEE_CLIENT_SECRET=
FREEE_REDIRECT_URI=
FREEE_TOKEN_ENCRYPTION_KEY=
FREEE_TOKEN_URL=https://accounts.secure.freee.co.jp/public_api/token
# Default queues/logs sync work. Set local_success only for non-production adapter testing.
FREEE_SYNC_MODE=queue
TRANSFER_PROVIDER_MODE=manual
TRANSFER_WEBHOOK_SECRET=

# Supabase Edge Function secrets are configured in the Supabase dashboard.
# They are not read from the Next.js app at runtime.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
